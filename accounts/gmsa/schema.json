{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "gMSA Declaration",
  "description": "SACM v2 — Declarative definition for an Active Directory Group Managed Service Account. Password managed natively by AD KDS.",
  "type": "object",
  "required": ["name", "environment", "type", "member_servers", "jira_ticket", "technical_owner", "status"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,20}$",
      "description": "Application short name without prefix. Combined with environment to form gmsa-{name}-{env}."
    },
    "environment": {
      "type": "string",
      "enum": ["prod", "staging", "dev"],
      "description": "Target environment."
    },
    "type": {
      "type": "string",
      "const": "gmsa",
      "description": "Account type identifier. Must be 'gmsa' for this schema."
    },
    "description": {
      "type": "string",
      "description": "Purpose of the gMSA."
    },
    "member_servers": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Server hostnames allowed to retrieve the gMSA password."
    },
    "spns": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Optional Service Principal Names (e.g., MSSQLSvc/host:port)."
    },
    "jira_ticket": {
      "type": "string",
      "pattern": "^[A-Z]+-\\d+$",
      "description": "SACM Jira ticket reference."
    },
    "technical_owner": {
      "type": "string",
      "description": "Email of the technical owner."
    },
    "business_owner": {
      "type": "string",
      "description": "Email of the business owner."
    },
    "privilege_level": {
      "type": "string",
      "enum": ["standard", "elevated", "privileged"],
      "description": "Privilege classification per SACM policy."
    },
    "created_date": {
      "type": "string",
      "format": "date",
      "description": "Date the gMSA was created (ISO 8601)."
    },
    "status": {
      "type": "string",
      "enum": ["active", "decommissioned", "suspended"],
      "description": "Current lifecycle status."
    }
  },
  "additionalProperties": false
}
